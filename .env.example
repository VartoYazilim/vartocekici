# Public site URL — must be the canonical, absolute URL of the deployed site.
# Used in metadata, sitemap, robots, hreflang, JSON-LD. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://vartocekici.com

# Optional: Google Search Console verification token (added to <head>)
# Get this from: https://search.google.com/search-console
NEXT_PUBLIC_GSC_VERIFICATION=

# Optional: Google Maps embed query string (set this when a GBP location is created).
# Example: "Varto+Çekici+Muş+Varto" or a place_id
NEXT_PUBLIC_MAPS_QUERY=
